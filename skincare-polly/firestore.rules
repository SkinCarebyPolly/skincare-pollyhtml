rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuário só acessa seus próprios dados
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /protocolos/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /evolucao/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
